<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Borde exterior -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#66FFFFFF" />
            <size
                android:width="38dp"
                android:height="38dp" />
        </shape>
    </item>
    <!-- Interior oscuro -->
    <item
        android:bottom="1.5dp"
        android:left="1.5dp"
        android:right="1.5dp"
        android:top="1.5dp">
        <shape android:shape="oval">
            <solid android:color="#99000000" />
        </shape>
    </item>
</layer-list>