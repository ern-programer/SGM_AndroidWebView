<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚙"
        android:textSize="48sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Configuración del Servidor"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Ingresá la dirección IP y puerto\ndel servidor SGM en la red local"
        android:textColor="#AAAAAA"
        android:textSize="13sp" />

    <!-- Indicador de red WiFi actual -->
    <TextView
        android:id="@+id/textSsid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="#16213e"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:text="📡 Detectando red..."
        android:textColor="#0288b8"
        android:textSize="13sp" />

    <EditText
        android:id="@+id/editIp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="#16213e"
        android:hint="IP del servidor (ej: 192.168.0.113)"
        android:inputType="text"
        android:padding="14dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#666666"
        android:textSize="15sp" />

    <EditText
        android:id="@+id/editPort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="#16213e"
        android:hint="Puerto (ej: 3000)"
        android:inputType="number"
        android:padding="14dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#666666"
        android:textSize="15sp" />

    <!-- Protocolo HTTP/HTTPS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="#16213e"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Usar HTTPS"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <Switch
            android:id="@+id/switchProtocol"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:thumbTint="#0288b8"
            android:trackTint="#333333" />

    </LinearLayout>

    <!-- Mostrar/ocultar pill de estado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="#16213e"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mostrar estado (batería + hora)"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <Switch
            android:id="@+id/switchPill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:thumbTint="#0288b8"
            android:trackTint="#333333" />

    </LinearLayout>

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:backgroundTint="#0288b8"
        android:text="✓ Guardar"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnDefault"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="#6c757d"
        android:text="Restaurar valores por defecto"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

</LinearLayout>